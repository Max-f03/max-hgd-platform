export default function ChatbotSettingsPage() {
  const [settings, setSettings] = useState<ChatbotSettings>({
    chatbotEnabled: true,
    chatbotUseAI: true,
    chatbotWelcome: "Bonjour ! Je suis l'assistant de Max. Comment puis-je vous aider ?",
    chatbotPersonality: "friendly",
    chatbotPrimaryColor: "#3B82F6",
    chatbotQuickActions: [
      { label: "Voir les projets", message: "Je voudrais voir vos projets" },
      { label: "Services", message: "Quels services proposez-vous ?" },
      { label: "Me contacter", message: "Je voudrais vous contacter" },
    ],
  });
  const [loading, setLoading] = useState(false);
  const [saving, setSaving] = useState(false);
  const [aiStatus, setAiStatus] = useState<{ aiEnabled: boolean; useAI: boolean; hasApiKey: boolean; provider: string } | null>(null);

  useEffect(() => {
    void fetchSettings();
    void fetch("/api/chatbot/status")
      .then((r) => r.json() as Promise<{ aiEnabled: boolean; useAI: boolean; hasApiKey: boolean; provider: string }>)
      .then(setAiStatus)
      .catch(() => null);
  }, []);

  const fetchSettings = async () => {
    setLoading(true);
    try {
      const response = await fetch("/api/settings");
      if (response.ok) {
        const data = (await response.json()) as Partial<ChatbotSettings>;
        setSettings({
          chatbotEnabled: data.chatbotEnabled ?? true,
          chatbotUseAI: data.chatbotUseAI ?? true,
          chatbotWelcome:
            data.chatbotWelcome ??
            "Bonjour ! Je suis l'assistant de Max. Comment puis-je vous aider ?",
          chatbotPersonality: data.chatbotPersonality ?? "friendly",
          chatbotPrimaryColor: data.chatbotPrimaryColor ?? "#3B82F6",
          chatbotQuickActions: data.chatbotQuickActions ?? [
            { label: "Voir les projets", message: "Je voudrais voir vos projets" },
            { label: "Services", message: "Quels services proposez-vous ?" },
            { label: "Me contacter", message: "Je voudrais vous contacter" },
          ],
        });
      }
    } catch (error) {
      console.error("Fetch settings error:", error);
    } finally {
      setLoading(false);
    }
  };

  const saveSettings = async () => {
    setSaving(true);
    try {
      const response = await fetch("/api/settings", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(settings),
      });

      if (response.ok) {
        toast.success("Parametres enregistres");
      } else {
        toast.error("Erreur lors de la sauvegarde");
      }
    } catch (error) {
      console.error("Save error:", error);
      toast.error("Erreur lors de la sauvegarde");
    } finally {
      setSaving(false);
    }
  };

  const addQuickAction = () => {
    setSettings((prev) => ({
      ...prev,
      chatbotQuickActions: [...prev.chatbotQuickActions, { label: "", message: "" }],
    }));
  };

  const removeQuickAction = (index: number) => {
    setSettings((prev) => ({
      ...prev,
      chatbotQuickActions: prev.chatbotQuickActions.filter((_, i) => i !== index),
    }));
  };

  const updateQuickAction = (
    index: number,
    field: "label" | "message",
    value: string
  ) => {
    setSettings((prev) => ({
      ...prev,
      chatbotQuickActions: prev.chatbotQuickActions.map((action, i) =>
        i === index ? { ...action, [field]: value } : action
      ),
    }));
  };

  if (loading) {
    return (
      <div className="flex h-96 items-center justify-center">
        <Loader2 className="h-8 w-8 animate-spin text-[var(--ui-primary)]" />
      </div>
    );
  }

  return (
    <div className="mx-auto w-full max-w-[1280px] p-6">
      <div className="grid gap-6 xl:grid-cols-[minmax(0,1fr)_380px]">
        <div className="space-y-6">
          <div className="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h1 className="text-2xl font-bold" style={{ color: "var(--ui-text)" }}>Configuration Chatbot</h1>
              <p className="mt-1" style={{ color: "var(--ui-text-secondary)" }}>
                Personnalisez l&apos;assistant qui repond a vos visiteurs
              </p>
            </div>
            <Button onClick={saveSettings} disabled={saving}>
              {saving ? (
                <Loader2 className="mr-2 h-4 w-4 animate-spin" />
              ) : (
                <Save className="mr-2 h-4 w-4" />
              )}
              Enregistrer
            </Button>
          </div>

          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <Bot className="h-5 w-5" />
                Activation
              </CardTitle>
            </CardHeader>
            <CardContent>
              <div className="flex items-center justify-between">
                <div>
                  <p className="font-medium" style={{ color: "var(--ui-text)" }}>Activer le chatbot</p>
                  <p className="text-sm" style={{ color: "var(--ui-text-secondary)" }}>
                    Le widget apparaitra en bas a droite du site public
                  </p>
                </div>
                <input
                  type="checkbox"
                  checked={settings.chatbotEnabled}
                  onChange={(e) =>
                    setSettings((prev) => ({ ...prev, chatbotEnabled: e.target.checked }))
                  }
                  className="h-5 w-5 cursor-pointer rounded border accent-[var(--ui-primary)]"
                  style={{ borderColor: "var(--ui-border)" }}
                />
              </div>

              <div className="border-t my-4" style={{ borderColor: "var(--ui-border)" }} />

              <div className="flex items-center justify-between">
                <div>
                  <p className="font-medium" style={{ color: "var(--ui-text)" }}>Utiliser l&apos;IA Groq</p>
                  <p className="text-sm" style={{ color: "var(--ui-text-secondary)" }}>
                    Reponses intelligentes generees par IA. Si desactive, le bot utilise des reponses predefinies.
                  </p>
                </div>
                <button
                  type="button"
                  role="switch"
                  aria-checked={settings.chatbotUseAI}
                  onClick={() => setSettings((prev) => ({ ...prev, chatbotUseAI: !prev.chatbotUseAI }))}
                  className="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 focus:outline-none"
                  style={{ background: settings.chatbotUseAI ? "var(--ui-primary)" : "var(--ui-border)" }}
                >
                  <span
                    className="inline-block h-5 w-5 transform rounded-full bg-white shadow-sm transition duration-200"
                    style={{ transform: settings.chatbotUseAI ? "translateX(20px)" : "translateX(0px)" }}
                  />
                </button>
              </div>

              <div
                className="mt-4 flex items-center gap-2.5 rounded-lg border p-3"
                style={{ borderColor: "var(--ui-border)", background: "var(--ui-input-bg)" }}
              >
                <Cpu
                  className="h-4 w-4 shrink-0"
                  style={{
                    color: !settings.chatbotUseAI
                      ? "var(--ui-text-muted)"
                      : aiStatus?.hasApiKey
                      ? "#22c55e"
                      : "#eab308",
                  }}
                />
                <div className="flex items-center gap-2">
                  <div
                    className="h-2 w-2 rounded-full"
                    style={{
                      background: !settings.chatbotUseAI
                        ? "#9ca3af"
                        : aiStatus?.hasApiKey
                        ? "#22c55e"
                        : "#eab308",
                    }}
                  />
                  <span className="text-sm" style={{ color: "var(--ui-text-secondary)" }}>
                    {!settings.chatbotUseAI
                      ? "IA desactivee — reponses predefinies"
                      : aiStatus?.hasApiKey
                      ? `IA ${aiStatus.provider} connectee`
                      : "Cle API manquante — reponses predefinies"}
                  </span>
                </div>
              </div>
            </CardContent>
          </Card>

          <Card>
            <CardHeader>
              <CardTitle>Apparence</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div>
                <label className="mb-2 block text-sm font-medium" style={{ color: "var(--ui-text)" }}>
                  Couleur principale
                </label>
                <div className="flex items-center gap-3">
                  <input
                    type="color"
                    value={settings.chatbotPrimaryColor}
                    onChange={(e) =>
                      setSettings((prev) => ({ ...prev, chatbotPrimaryColor: e.target.value }))
                    }
                    className="h-12 w-12 cursor-pointer rounded-lg border-0"
                  />
                  <input
                    type="text"
                    value={settings.chatbotPrimaryColor}
                    onChange={(e) =>
                      setSettings((prev) => ({ ...prev, chatbotPrimaryColor: e.target.value }))
                    }
                    className="h-10 w-28 rounded-lg border px-3 font-mono"
                    style={{ borderColor: "var(--ui-border)", background: "var(--ui-input-bg)", color: "var(--ui-text)" }}
                  />
                </div>
              </div>
            </CardContent>
          </Card>

          <Card>
            <CardHeader>
              <CardTitle>Message de bienvenue</CardTitle>
            </CardHeader>
            <CardContent>
              <Textarea
                value={settings.chatbotWelcome}
                onChange={(e) =>
                  setSettings((prev) => ({ ...prev, chatbotWelcome: e.target.value }))
                }
                placeholder="Bonjour ! Comment puis-je vous aider ?"
                rows={3}
              />
              <p className="mt-2 text-sm" style={{ color: "var(--ui-text-muted)" }}>
                Ce message s&apos;affiche quand le visiteur ouvre le chat
              </p>
            </CardContent>
          </Card>

          <Card>
            <CardHeader>
              <CardTitle>Personnalite</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="grid grid-cols-1 gap-3 md:grid-cols-2">
                {personalities.map((p) => (
                  <button
                    key={p.value}
                    onClick={() =>
                      setSettings((prev) => ({ ...prev, chatbotPersonality: p.value }))
                    }
                    className="rounded-lg border p-4 text-left transition-colors"
                    style={
                      settings.chatbotPersonality === p.value
                        ? { borderColor: "var(--ui-primary)", background: "var(--ui-primary-soft)" }
                        : { borderColor: "var(--ui-border)", background: "transparent" }
                    }
                  >
                    <p className="font-medium" style={{ color: "var(--ui-text)" }}>{p.label}</p>
                    <p className="text-sm" style={{ color: "var(--ui-text-secondary)" }}>{p.description}</p>
                  </button>
                ))}
              </div>
            </CardContent>
          </Card>

          <Card>
            <CardHeader>
              <div className="flex items-center justify-between">
                <CardTitle>Actions rapides</CardTitle>
                <Button variant="outline" size="sm" onClick={addQuickAction}>
                  <Plus className="mr-1 h-4 w-4" />
                  Ajouter
                </Button>
              </div>
            </CardHeader>
            <CardContent className="space-y-4">
              {settings.chatbotQuickActions.length === 0 ? (
                <p className="py-4 text-center" style={{ color: "var(--ui-text-muted)" }}>
                  Aucune action rapide. Cliquez sur &quot;Ajouter&quot; pour en creer.
                </p>
              ) : (
                settings.chatbotQuickActions.map((action, index) => (
                  <div key={index} className="flex items-start gap-3">
                    <div className="grid flex-1 grid-cols-1 gap-3 md:grid-cols-2">
                      <Input
                        placeholder="Label du bouton"
                        value={action.label}
                        onChange={(e) => updateQuickAction(index, "label", e.target.value)}
                      />
                      <Input
                        placeholder="Message envoye"
                        value={action.message}
                        onChange={(e) => updateQuickAction(index, "message", e.target.value)}
                      />
                    </div>
                    <button
                      onClick={() => removeQuickAction(index)}
                      className="rounded-lg p-2 text-red-500 transition-colors hover:bg-red-50"
                    >
                      <Trash2 className="h-4 w-4" />
                    </button>
                  </div>
                ))
              )}
              <p className="text-sm" style={{ color: "var(--ui-text-muted)" }}>
                Ces boutons apparaissent au debut de la conversation pour guider le visiteur
              </p>
            </CardContent>
          </Card>
        </div>

        <div className="hidden xl:block">
          <ChatbotPreview settings={settings} />
        </div>
      </div>

      <div className="mt-6 xl:hidden">
        <ChatbotPreview settings={settings} />
      </div>
    </div>
  );
}

              </div>
            </div>
          </div>

          <div className="rounded-xl border p-3 text-xs" style={{ borderColor: "var(--ui-border)", color: "var(--ui-text-secondary)", background: "var(--ui-input-bg)" }}>
            Personnalite active: <span className="font-semibold" style={{ color: "var(--ui-text)" }}>{personalities.find((p) => p.value === settings.chatbotPersonality)?.label ?? "Amical"}</span>
          </div>
